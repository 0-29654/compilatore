<Window x:Class="CppStudentClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="C++ Compiti - Alunno" Width="1100" Height="760"
        WindowStartupLocation="CenterScreen" Background="#0B1020">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="#111A33" CornerRadius="12" Padding="10" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                    <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="3">
                    <TextBlock Text="ID alunno" Foreground="White"/><TextBox x:Name="StudentIdBox"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="3">
                    <TextBlock Text="Nome e cognome" Foreground="White"/><TextBox x:Name="StudentNameBox"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="3">
                    <TextBlock Text="Classe" Foreground="White"/><TextBox x:Name="ClassBox"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="3" Margin="3">
                    <TextBlock Text="ID esercizio" Foreground="White"/><TextBox x:Name="ExerciseBox"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="4" Margin="3">
                    <TextBlock Text="IP docente:porta" Foreground="White"/><TextBox x:Name="ServerBox" Text="192.168.1.50:5050"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="5" Margin="3">
                    <TextBlock Text="Codice sessione" Foreground="White"/><TextBox x:Name="SessionBox"/>
                </StackPanel>

                <Grid Grid.Row="1" Grid.ColumnSpan="6" Margin="3,8,3,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Compilatore:" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="CompilerPathBox" Grid.Column="1" IsReadOnly="True" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="Scegli g++.exe" Click="ChooseCompiler_Click" Padding="12,5" Margin="0,0,8,0"/>
                    <Button Grid.Column="3" Content="Test server docente" Click="TestServer_Click" Padding="12,5" Background="#7C3AED" Foreground="White"/>
                </Grid>
            </Grid>
        </Border>

        <avalonEdit:TextEditor x:Name="Editor" Grid.Row="1" ShowLineNumbers="True" FontFamily="Consolas" FontSize="15"/>
        <TextBox x:Name="OutputBox" Grid.Row="2" Margin="0,8,0,8" IsReadOnly="True" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <Button Content="Compila" Click="Compile_Click" Padding="18,8"/>
            <Button Content="Compila e apri CMD" Click="Run_Click" Padding="18,8"/>
            <Button Content="Invia al docente" Click="Send_Click" Padding="18,8" Background="#0EA5E9" Foreground="White" FontWeight="Bold"/>
            <TextBlock x:Name="StatusText" Foreground="White" VerticalAlignment="Center" Margin="12,0"/>
        </StackPanel>
    </Grid>
</Window>
