<Window x:Class="CppStudentClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="CV+ Compilatore Alunno" Width="1280" Height="860" MinWidth="1080" MinHeight="720"
        WindowStartupLocation="CenterScreen" WindowState="Maximized" Background="#07111F" Icon="Assets/app.ico"
        PreviewKeyDown="Window_PreviewKeyDown" Deactivated="Window_Deactivated" Closing="Window_Closing">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#101D31"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#18A9F5"/>
        <SolidColorBrush x:Key="TextBrush" Color="#F5F8FC"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#A8B5C7"/>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0A1526"/>
            <Setter Property="Foreground" Value="#F5F8FC"/>
            <Setter Property="BorderBrush" Value="#2A3A52"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="9,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#0A1526"/>
            <Setter Property="Foreground" Value="#F5F8FC"/>
            <Setter Property="BorderBrush" Value="#2A3A52"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="1,0,0,5"/>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#24344D"/>
            <Setter Property="BorderBrush" Value="#354966"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,9"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Root" Property="Opacity" Value="0.86"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Root" Property="Opacity" Value="0.42"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootLayout">
        <Grid.RowDefinitions>
            <RowDefinition Height="108"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="125"/>
            <RowDefinition Height="82"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0B1729" BorderBrush="#20324C" BorderThickness="0,0,0,1">
            <Grid Margin="22,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <Border Width="58" Height="58" CornerRadius="15" Background="#0E5DA8" VerticalAlignment="Center">
                    <TextBlock Text="C++" Foreground="#AEE8FF" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock Text="CV+ Compilatore Alunno" Foreground="White" FontSize="25" FontWeight="Bold"/>
                    <TextBlock Text="Scrivi, compila in C++17 e invia il tuo esercizio al docente" Foreground="{StaticResource MutedBrush}" FontSize="13" Margin="0,4,0,0"/>
                    <TextBlock Text="© Alessandro Barazzuol" Foreground="#8FE8FF" FontSize="16" FontWeight="Bold" Margin="0,6,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Border Background="#0F3550" BorderBrush="#2AAEFF" BorderThickness="1"
                                CornerRadius="11" Padding="12,6" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="STANDARD" Foreground="#A8B5C7" FontSize="10"
                                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock Text="C++17" Foreground="#B7F3FF" FontWeight="ExtraBold" FontSize="13"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="ModeBadge" Background="#102D25" BorderBrush="#1F6D55"
                                BorderThickness="1" CornerRadius="14" Padding="12,7">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="ModeDot" Width="8" Height="8" Fill="#34D399"
                                         VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock x:Name="ModeText" Text="ESERCITAZIONE"
                                           Foreground="#B9F7DC" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="Compilatore C++17 incluso nell'installazione"
                               Foreground="#7E93AE" FontSize="10" HorizontalAlignment="Right"
                               Margin="0,5,2,0"/>
                    <TextBlock x:Name="ExerciseTimeText" Text="Tempo esercizio: 00:00:00"
                               Foreground="#91A4BD" FontSize="11" HorizontalAlignment="Right"
                               Margin="0,4,2,0"/>
                    <TextBlock x:Name="LocalIpText" Text="IP: rilevamento..."
                               Foreground="#6F849F" FontSize="10" HorizontalAlignment="Right"
                               Margin="0,2,2,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="14" Margin="16,14,16,10" Padding="14"
                BorderBrush="#243650" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.72*"/><ColumnDefinition Width="1.25*"/><ColumnDefinition Width="0.62*"/>
                    <ColumnDefinition Width="0.78*"/><ColumnDefinition Width="0.72*"/><ColumnDefinition Width="1.10*"/>
                    <ColumnDefinition Width="0.78*"/><ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="4"><TextBlock Text="N° REGISTRO ALU." Style="{StaticResource LabelStyle}"/><TextBox x:Name="StudentIdBox"/></StackPanel>
                <StackPanel Grid.Column="1" Margin="4"><TextBlock Text="NOME E COGNOME" Style="{StaticResource LabelStyle}"/><TextBox x:Name="StudentNameBox"/></StackPanel>
                <StackPanel Grid.Column="2" Margin="4"><TextBlock Text="CLASSE" Style="{StaticResource LabelStyle}"/><TextBox x:Name="ClassBox"/></StackPanel>
                <StackPanel Grid.Column="3" Margin="4"><TextBlock Text="TIPOLOGIA" Style="{StaticResource LabelStyle}"/><TextBox x:Name="TaskTypeBox" Text="A" LostFocus="TaskIdentity_LostFocus"/></StackPanel>
                <StackPanel Grid.Column="4" Margin="4"><TextBlock Text="N° ESERCIZIO" Style="{StaticResource LabelStyle}"/><TextBox x:Name="ExerciseBox" Text="1" LostFocus="TaskIdentity_LostFocus"/></StackPanel>
                <StackPanel Grid.Column="5" Margin="4"><TextBlock Text="IP DOCENTE : PORTA" Style="{StaticResource LabelStyle}"/><TextBox x:Name="ServerBox" Text=""/></StackPanel>
                <StackPanel Grid.Column="6" Margin="4"><TextBlock Text="CODICE SESSIONE" Style="{StaticResource LabelStyle}"/><TextBox x:Name="SessionBox"/></StackPanel>
                <StackPanel Grid.Column="7" Margin="4">
                    <TextBlock Text="CAMBIA ESERCIZIO" Style="{StaticResource LabelStyle}"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="◀" Width="42" Click="PreviousExercise_Click" Style="{StaticResource ModernButton}" Padding="8,7"/>
                        <Button Content="▶" Width="42" Click="NextExercise_Click" Style="{StaticResource ModernButton}" Padding="8,7" Margin="0" Background="#0E78C7" BorderBrush="#2AAEFF"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Margin="16,0,16,0" CornerRadius="14" Background="#050B14" BorderBrush="#2B4567" BorderThickness="1" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="38"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Border Background="#102540" BorderBrush="#2B4567" BorderThickness="0,0,0,1">
                    <Grid Margin="12,0"><TextBlock Text="main.cpp" Foreground="#F1F7FF" FontWeight="SemiBold" VerticalAlignment="Center"/><TextBlock Text="SHIFT+CLICK: editor a tutto schermo • C++17" Foreground="#FFD166" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid>
                </Border>
                <TabControl Grid.Row="1" Background="#050B14" BorderThickness="0">
                    <TabItem Header="main.cpp">
                        <avalonEdit:TextEditor x:Name="Editor" ShowLineNumbers="True" FontFamily="Cascadia Mono, Consolas" FontSize="16"
                                               Background="#050B14" Foreground="#F7FBFF" LineNumbersForeground="#7690B1" Padding="10"
                                               TextChanged="Editor_TextChanged" PreviewMouseLeftButtonDown="Editor_PreviewMouseLeftButtonDown"/>
                    </TabItem>
                    <TabItem x:Name="HeaderTab" Header="esercizio.h" Visibility="Collapsed">
                        <avalonEdit:TextEditor x:Name="HeaderEditor" ShowLineNumbers="True" FontFamily="Cascadia Mono, Consolas" FontSize="16"
                                               Background="#050B14" Foreground="#F7FBFF" LineNumbersForeground="#7690B1" Padding="10"
                                               TextChanged="HeaderEditor_TextChanged" PreviewMouseLeftButtonDown="HeaderEditor_PreviewMouseLeftButtonDown"/>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>

        <Border Grid.Row="3" Margin="16,10,16,0" CornerRadius="14" Background="{StaticResource PanelBrush}" BorderBrush="#243650" BorderThickness="1" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="36"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Border Background="#132139"><Grid Margin="13,0"><TextBlock Text="COMPILAZIONE ED ESECUZIONE" Foreground="#BBD0E8" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/><TextBlock Text="SHIFT+CLICK: apri a tutto schermo" Foreground="#FFD166" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/></Grid></Border>
                <TextBox x:Name="OutputBox" Grid.Row="1" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap" BorderThickness="0" Background="#07101C" Foreground="#E7F4FF" FontFamily="Cascadia Mono, Consolas" Padding="12" PreviewMouseLeftButtonDown="OutputBox_PreviewMouseLeftButtonDown"/>
            </Grid>
        </Border>

        <Border Grid.Row="4" Background="#0B1729" BorderBrush="#20324C"
                BorderThickness="0,1,0,0" Margin="0,8,0,0">
            <Grid Margin="14,7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="RunButton" Grid.Column="0" Content="Compila ed esegui"
                        Click="Run_Click" Style="{StaticResource ModernButton}"
                        Background="#059669" BorderBrush="#19C790" VerticalAlignment="Center"/>

                <Button Grid.Column="1" Content="Aggiungi esercizio.h"
                        Click="AddHeader_Click" Style="{StaticResource ModernButton}"
                        Background="#7C3AED" BorderBrush="#9F7AEA" VerticalAlignment="Center"/>

                <Button x:Name="RenameHeaderButton" Grid.Column="2" Content="Rinomina .h"
                        Click="RenameHeader_Click" Style="{StaticResource ModernButton}"
                        Background="#9333EA" BorderBrush="#C084FC" VerticalAlignment="Center"/>

                <Button x:Name="DeleteHeaderButton" Grid.Column="3" Content="Elimina .h"
                        Click="DeleteHeader_Click" Style="{StaticResource ModernButton}"
                        Background="#B91C1C" BorderBrush="#F87171" VerticalAlignment="Center"/>

                <Button x:Name="SendButton" Grid.Column="4" Content="Invia al docente"
                        Click="Send_Click" Style="{StaticResource ModernButton}"
                        Background="#0E8FE8" BorderBrush="#44B7FF" VerticalAlignment="Center"/>

                <TextBlock x:Name="CurrentTaskSummaryText" Grid.Column="5"
                           Text="Tipologia — • esercizio 1" Foreground="#BDD6F3"
                           FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                           Margin="8,0,10,0"/>

                <Button x:Name="TestServerButton" Grid.Column="6" Content="Test server"
                        Click="TestServer_Click" Style="{StaticResource ModernButton}"
                        Background="#5B4FE8" BorderBrush="#746BFF" VerticalAlignment="Center"/>

                <ProgressBar x:Name="ServerTestProgress" Grid.Column="7"
                             Height="8" Margin="4,0,12,0" IsIndeterminate="True"
                             Visibility="Collapsed" VerticalAlignment="Center"
                             Foreground="#47D7FF" Background="#10243A"/>

                <TextBlock x:Name="StatusText" Grid.Column="8" Text="Pronto"
                           Foreground="#A8B5C7" VerticalAlignment="Center" Margin="8,0"/>

                <Button x:Name="UpdateButton" Grid.Column="9" Content="Ricerca aggiornamenti"
                        Click="CheckUpdates_Click" Style="{StaticResource ModernButton}"
                        Background="#0F4C75" BorderBrush="#38BDF8" VerticalAlignment="Center"
                        Margin="8,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>